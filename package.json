{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    },
    {
      "src": "**/*.html",
      "use": "@vercel/static"
    },
    {
      "src": "css/**/*.css",
      "use": "@vercel/static"
    },
    {
      "src": "images/**/*",
      "use": "@vercel/static"
    }
  ],
  "rewrites": [
    { "source": "/cek-ongkir", "destination": "/server.js" },
    { "source": "/buat-transaksi", "destination": "/server.js" },
    { "source": "/buat-resi", "destination": "/server.js" },
    { "source": "/kirim-invoice", "destination": "/server.js" }
  ]
}